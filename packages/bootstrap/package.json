{
  "name": "@bmi/bootstrap",
  "version": "1.0.0",
  "description": "Platform Context initialization factory",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
