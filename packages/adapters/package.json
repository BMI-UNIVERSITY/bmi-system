    "clean": "rm -rf dist",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@bmi/ports": "*",
    "@keycloak/keycloak-admin-client": "^26.6.4",
    "pdf-lib": "^1.17.1",
    "stripe": "^14.14.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260701.1",
    "@types/pg": "^8.20.0",
    "typescript": "^5.8.2",
    "vitest": "^4.1.10"
  }
}
