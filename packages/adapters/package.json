{
  "name": "@bmi/adapters",
  "version": "1.0.0",
  "description": "Platform-specific adapters for the BMI System Hexagonal Architecture",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
