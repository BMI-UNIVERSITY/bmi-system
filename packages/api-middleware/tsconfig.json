{
  "compilerOptions": {
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "declaration": true,
    "outDir": "./dist",
    "strict": true,
    "types": ["@cloudflare/workers-types"],
    "lib": ["ESNext"],
    "skipLibCheck": true
  },
  "include": ["src/**/*"]
}
