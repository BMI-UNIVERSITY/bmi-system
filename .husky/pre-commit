# Skip type-check if env var SKIP_CI=true (pre-commit runs before commit exists,
# so commit-message check is handled in pre-push instead)
if [ "$SKIP_CI" = "true" ]; then
  echo "⏩ Skipping type-check (SKIP_CI=true)"
else
  npx turbo run lint type-check --concurrency=100%
fi

# Basic Secret Scanning
if git diff --cached | grep -iE "(API_KEY|SECRET|PASSWORD|TOKEN).{0,5}=" > /dev/null; then
  echo "🚨 ERROR: Potential secrets found in staged files. Remove them before committing."
  exit 1
fi
