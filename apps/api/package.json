{
  "name": "@bmi/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --local",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 migrations apply bmi-portal-db --remote",
    "db:migrate:local": "wrangler d1 migrations apply bmi-portal-db --local",
    "verify-migrations": "tsx scripts/verify-migrations.ts",
    "type-check": "tsc --noEmit",
    "secrets:set": "node scripts/set-secrets.mjs",
    "test": "vitest run --passWithNoTests",
    "test:integration": "vitest run -c vitest.integration.config.ts",
    "lint": "eslint ."
  },
  "dependencies": {
    "@bmi/adapters": "file:../../packages/adapters",
    "@bmi/bootstrap": "file:../../packages/bootstrap",
    "@bmi/ports": "file:../../packages/ports",
    "@bmi/shared": "file:../../packages/shared",
    "@sentry/cloudflare": "10.62.0",
    "better-sqlite3": "^12.11.1",
    "jpeg-js": "^0.4.4",
    "pngjs": "^5.0.0",
    "zod": "3.25.67"
  },
  "devDependencies": {
    "@cloudflare/unenv-preset": "^2.16.1",
    "@cloudflare/vitest-pool-workers": "0.16.20",
    "@cloudflare/workers-types": "^4.20260701.1",
    "@types/jpeg-js": "^0.3.0",
    "@types/node": "^26.1.1",
    "@types/pngjs": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "9.39.4",
    "typescript": "5.8.2",
    "typescript-eslint": "8.62.1",
    "vitest": "^4.1.10",
    "wrangler": "^4.107.0"
  }
}
