{
  "name": "@bmi/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --local",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 execute bmi-portal-db --file=db/schema.sql --remote",
    "db:migrate:local": "wrangler d1 execute bmi-portal-db --file=db/schema.sql --local",
    "type-check": "tsc --noEmit",
    "secrets:set": "node scripts/set-secrets.mjs",
    "test": "vitest run"
  },
  "dependencies": {
    "@bmi/shared": "*",
    "@sentry/cloudflare": "^10.62.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.20",
    "@cloudflare/workers-types": "^4.20260625.1",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9",
    "wrangler": "^4.104.0"
  }
}
