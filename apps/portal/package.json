{
  "name": "bmi-portal",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler deploy",
    "db:migrate": "wrangler d1 execute bmi-portal-db --file=worker/db/schema.sql",
    "db:seed-admin": "node scripts/seed-admin.mjs",
    "db:seed-admin:execute": "wrangler d1 execute bmi-portal-db --command=\"$(node scripts/seed-admin.mjs)\"",
    "test": "vitest",
    "test:ui": "vitest --ui"
  },
  "devDependencies": {
    
    "@cloudflare/workers-types": "^4.20260625.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/ui": "^4.1.9",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9",
    "wrangler": "^4.104.0"
  },
  "dependencies": {
    "@bmi/shared": "*",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0"
  },
  "optionalDependencies": {
    "@rolldown/binding-linux-x64-gnu": "1.1.3"
  }
}

