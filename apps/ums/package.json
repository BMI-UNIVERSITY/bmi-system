{
  "name": "bmi-ums-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "BMI University Management System - 100% Open Source Frontend",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "type-check": "tsc --noEmit",
    "prepare": "husky",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "start": "powershell -ExecutionPolicy Bypass -File scripts/dev/start-all.ps1",
    "stop": "powershell -ExecutionPolicy Bypass -File scripts/dev/stop-all-windows.ps1",
    "create-admin": "tsx scripts/create-admin-auto.ts",
    "import-data": "tsx scripts/import-accurate-data.ts",
    "sync-to-sheets": "tsx scripts/sync-to-sheets.ts",
    "test:unit": "vitest run --reporter=verbose",
    "test:e2e": "playwright test --pass-with-no-tests",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "tunnel": "node scripts/ngrok-tunnel.cjs",
    "proxy": "node scripts/local-proxy.cjs"
  },
  "dependencies": {
    "@bmi/shared": "file:../../packages/shared",
    "@sentry/browser": "^10.62.0",
    "@sentry/react": "^10.62.0",
    "@tanstack/react-query": "^5.80.2",
    "csv-parser": "^3.2.1",
    "csv-writer": "^1.6.0",
    "docx": "^9.6.1",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.5",
    "html2pdf.js": "^0.14.0",
    "i18next": "^26.3.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^4.0.0",
    "jsqr": "^1.4.0",
    "lucide-react": "^1.17.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.18.0",
    "recharts": "^3.5.1",
    "zustand": "^5.0.13"
  },
  "optionalDependencies": {
    "@rolldown/binding-linux-x64-gnu": "1.0.2",
    "@rollup/rollup-linux-x64-gnu": "4.60.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^26.1.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.60.0",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "autoprefixer": "^10.4.23",
    "axe-core": "^4.10.3",
    "csv-parse": "^6.2.1",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "google-auth-library": "^10.6.2",
    "googleapis": "^173.0.0",
    "happy-dom": "^20.10.6",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.6",
    "react-is": "^18.3.1",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.22.3",
    "typescript": "^5.8.2",
    "vite": "^8.1.3",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KIAI-JOSEPH/BMI-PORTAL.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/KIAI-JOSEPH/BMI-PORTAL/issues"
  },
  "homepage": "https://github.com/KIAI-JOSEPH/BMI-PORTAL#readme"
}
