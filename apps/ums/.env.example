# Frontend Environment Variables Example
# Copy this file to .env and fill in your values

# ─── API Configuration ─────────────────────────────────────────────────────────
# REQUIRED. Must point at the deployed BMI API server.
#
#   Development  →  http://localhost:3001   (vite dev proxy forwards /api here)
#   Production   →  https://bmi-api.bmiuniversity107.workers.dev   (Cloudflare Pages env)
#
# If this variable is missing in a production build, `src/services/config.ts`
# falls back to the production URL above so login cannot silently break, but
# you should ALWAYS set it explicitly in Cloudflare Pages → Settings →
# Environment variables for the production build.
VITE_API_URL=http://localhost:3001


# Feature Flags
VITE_ENABLE_AI=true
VITE_ENABLE_ANALYTICS=false

# Development
VITE_DEBUG=false

# Public verification portal URL (used in QR codes on printed documents).
# Leave empty for dev (uses localhost). Set in production to your real domain.
# VITE_VERIFY_URL=https://verify.bmiuniversity.ac.ke
VITE_VERIFY_URL=

