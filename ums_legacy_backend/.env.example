# BMI UMS Backend — Environment Variables
# Copy this file to .env and fill in every value before starting the server.
# Generate secrets with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# ── Security (REQUIRED — generate unique values, never reuse across deployments) ──
JWT_SECRET=your-super-secret-jwt-key-change-in-production
REFRESH_SECRET=your-refresh-token-secret-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
ENCRYPTION_KEY=your-32-char-encryption-key!

# ── JWT Algorithm ──────────────────────────────────────────────────────────────
# For RS256 (recommended in production): set both keys in PEM format.
# If omitted the server falls back to HS256 using JWT_SECRET.
# JWT_PRIVATE_KEY=
# JWT_PUBLIC_KEY=

# ── PocketBase ─────────────────────────────────────────────────────────────────
POCKETBASE_URL=http://127.0.0.1:8090
POCKETBASE_ADMIN_EMAIL=admin@bmi.edu
POCKETBASE_ADMIN_PASSWORD=

# ── Ollama AI (optional — leave blank to disable AI features) ─────────────────
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

# ── CORS ───────────────────────────────────────────────────────────────────────
# In production set this to your frontend domain, e.g. https://ums.bmi.ac.ke
CORS_ORIGIN=http://localhost:3000

# ── Redis (optional — enables multi-instance token blacklisting) ──────────────
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Document signing keys (separate from JWT — rotate independently)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CERT_SIGNING_SECRET=
CERT_OFFLINE_SECRET=

# Public verification portal URL (used in QR codes — set to your real domain in production)
VERIFY_PORTAL_URL=

# 🛡️ Litestream Configuration 🛡️
# REQUIRED: Set to your actual S3 bucket name before going live
LITESTREAM_S3_BUCKET=bmi-ums-backup-CHANGEME
LITESTREAM_ACCESS_KEY_ID=
LITESTREAM_SECRET_ACCESS_KEY=
LITESTREAM_ENDPOINT=

# 🛡️ PocketBase Encryption 🛡️
PB_ENCRYPTION_KEY=
