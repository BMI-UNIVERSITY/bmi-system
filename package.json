{
  "name": "bmi-system",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "prepare": "husky",
    "ci:build": "turbo run build --filter=./packages/*",
    "ci:typecheck": "turbo run type-check typecheck",
    "ci:test": "turbo run test",
    "ci:lint": "turbo run lint",
    "ci:all": "turbo run build lint type-check test --concurrency=100%"
  },

  "optionalDependencies": {
    "@tailwindcss/oxide-linux-x64-gnu": "^4.3.2",
    "lightningcss-linux-x64-gnu": "1.32.0"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "postcss": "^8.5.22",
    "turbo": "^2.4.4"
  }
}
