{
  "name": "bmi-system",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "prepare": "husky",
    "ci:build": "turbo run build --filter=./packages/*",
    "ci:typecheck": "turbo run type-check typecheck",
    "ci:test": "turbo run test",
    "ci:lint": "turbo run lint",
    "ci:all": "turbo run build lint type-check test --concurrency=100%"
  },
  "optionalDependencies": {
    "@tailwindcss/oxide-linux-x64-gnu": "^4.3.2",
    "lightningcss-linux-x64-gnu": "1.32.0"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "postcss": "^8.5.23",
    "turbo": "^2.4.4"
  },
  "pnpm.overrides": {
    "cookie": "^0.7.0",
    "esbuild": "^0.25.0",
    "postcss": "^8.5.18",
    "undici": "^6.26.1",
    "uuid": "^11.1.1",
    "ws": "^8.20.2",
    "sharp": "^0.35.0",
    "react-router": "^8.3.0",
    "next>postcss": "^8.5.18",
    "next>sharp": "^0.35.0",
    "exceljs>uuid": "^11.1.1"
  }
}
